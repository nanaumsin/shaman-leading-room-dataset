     "text": [
      "총 470개의 투자 관련 영상에서 댓글 수집을 시작합니다...\n",
      "\n",
      "✨ 수집 완료! 총 4913개의 댓글이 'investment_comments.csv' 파일로 안전하게 저장되었습니다.\n"
     ]
    }
   ],
   "source": [
    "import pandas as pd\n",
    "from googleapiclient.discovery import build\n",
    "from googleapiclient.errors import HttpError\n",
    "\n",
    "# =====================================================================\n",
    "# 0. 사용자 설정 (이 부분만 본인 환경에 맞게 수정하세요)\n",
    "# =====================================================================\n",
    "CSV_FILE_PATH = 'youtube_videos_full1.csv'\n",
    "YOUTUBE_API_KEY = 'YOUR API KEY'  # 발급받은 실제 API 키를 넣으세요
    "OUTPUT_FILE_PATH = 'investment_comments.csv'   # 저장할 결과 CSV 파일명
    "\n",
    "# 이전 파일 구조 반영 (영상제목: title, 영상키: video_id)\n",
    "VIDEO_TITLE_COL = 'title'\n",
    "VIDEO_ID_COL = 'video_id'\n",
    "\n",
    "\n",
    "# =====================================================================\n",
    "# 1. CSV 데이터 로드 및 주식/코인 영상 필터링\n",
    "# =====================================================================\n",
    "df = pd.read_csv(CSV_FILE_PATH)\n",
    "\n",
    "# 제목에 투자 관련 키워드가 포함된 영상만 필터링\n",
    "search_keywords = '주식|코인|비트코인|증시|투자|재테크'\n",
    "filtered_df = df[df[VIDEO_TITLE_COL].str.contains(search_keywords, na=False, case=False)]\n",
    "\n",
    "# 영상 ID와 제목을 매핑하여 딕셔너리로 저장\n",
    "video_dict = dict(zip(filtered_df[VIDEO_ID_COL], filtered_df[VIDEO_TITLE_COL]))\n",
    "video_ids = list(video_dict.keys())\n",
    "\n",
    "\n",
    "# =====================================================================\n",
    "# 2. 유튜브 API를 이용한 댓글 수집\n",
    "# =====================================================================\n",
    "youtube = build('youtube', 'v3', developerKey=YOUTUBE_API_KEY)\n",
    "collected_data = []\n",
    "\n",
    "print(f\"총 {len(video_ids)}개의 투자 관련 영상에서 댓글 수집을 시작합니다...\")\n",
    "\n",
    "for v_id in video_ids:\n",
    "    v_title = video_dict[v_id]\n",
    "    try:\n",
    "        # 각 영상당 최신 댓글 최대 100개씩 수집 (필요시 maxResults 조절 가능, 최대 100)\n",
    "        response = youtube.commentThreads().list(\n",
    "            part='snippet',\n",
    "            videoId=v_id,\n",
    "            maxResults=100,\n",
    "            textFormat='plainText'\n",
    "        ).execute()\n",
    "        \n",
    "        for item in response.get('items', []):\n",
    "            comment = item['snippet']['topLevelComment']['snippet']['textDisplay']\n",
    "            \n",
    "            # 영상 정보와 댓글을 매칭하여 리스트에 추가\n",
    "            collected_data.append({\n",
    "                'video_id': v_id,\n",
    "                'video_title': v_title,\n",
    "                'comment': comment\n",
    "            })\n",
    "            \n",
    "    except HttpError as e:\n",
    "        # 댓글 창이 비활성화되어 있거나 비공개된 영상은 건너뜁니다.\n",
    "        continue\n",
    "\n",
    "\n",
    "# =====================================================================\n",
    "# 3. 추출된 데이터를 데이터프레임으로 변환 후 CSV 저장\n",
    "# =====================================================================\n",
    "result_df = pd.DataFrame(collected_data)\n",
    "\n",
    "if not result_df.empty:\n",
    "    # 인코딩을 utf-8-sig로 해야 엑셀(Excel)에서 한글이 깨지지 않고 잘 열립니다.\n",
    "    result_df.to_csv(OUTPUT_FILE_PATH, index=False, encoding='utf-8-sig')\n",
    "    print(f\"\\n수집 완료! 총 {len(result_df)}개의 댓글이 '{OUTPUT_FILE_PATH}' 파일로 안전하게 저장되었습니다.\")\n",
    "else:\n",
    "    print(\"\\n수집된 댓글이 없습니다. API 키 또는 원본 파일의 데이터를 다시 확인해 주세요.\")"
   ]
  }
 ],
